# 本番（テスト公開）ビルド用の環境変数の雛形。
# `.env.production` にコピーして実値を入れる（.env.production は gitignore 済み・コミットしない）。
# ここに入るのはすべて「公開可能キー」（フロントに埋め込まれる前提の値）だが、運用として実値はコミットしない。

# バックエンド（Render）のURL（例: https://arigato-api.onrender.com）
VITE_API_URL=

# Stripe の公開可能キー（pk_test_... テストモードのまま）
VITE_STRIPE_PUBLISHABLE_KEY=

# Supabase（開発プロジェクトを共用。本番ローンチ時に本番プロジェクトの値へ差し替え）
VITE_SUPABASE_URL=
VITE_SUPABASE_PUBLISHABLE_KEY=

# Google Analytics（任意）
VITE_GA_ID=

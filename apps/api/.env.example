# API サーバの待ち受けポート（未設定なら 8787）
PORT=8787

# Supabase（PostgreSQL）接続文字列。未設定でもサーバ起動・/health は動く。
DATABASE_URL=

# Stripe シークレットキー（バックの決済処理）。テストは sk_test_... 。🔒秘匿・コミット禁止
STRIPE_SECRET_KEY=

# Stripe Webhook 署名シークレット。Stripe CLI / ダッシュボードで発行する whsec_... 。🔒秘匿
STRIPE_WEBHOOK_SECRET=

# Supabase Auth（プロジェクトURL）。JWKS公開鍵の取得・管理アクセスに使う
SUPABASE_URL=
# Supabase 新方式 Secret key（バックの管理アクセス）。🔒秘匿
SUPABASE_SECRET_KEY=

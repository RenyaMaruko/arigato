{
  "name": "arigato",
  "version": "0.1.0",
  "private": true,
  "description": "リアル投げ銭サービス Arigato のモノレポ",
  "packageManager": "pnpm@8.15.9",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "turbo run build",
